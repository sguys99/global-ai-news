# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# 검색 인덱스: prebuild/deploy.yml 빌드 시 data/app.db에서 생성(커밋하지 않음).
/public/search-index.json

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
Thumbs.db

# data artifacts (keep folder structure, ignore contents)
/data/raw/*
/data/intermediate/*
/data/processed/*
!/data/**/.gitkeep

# SQLite DB: app.db는 빌드 시 readonly 조회용으로 git에 포함(커밋).
# WAL/SHM은 실행 중에만 생기는 임시 파일이므로 무시.
/data/app.db-wal
/data/app.db-shm
