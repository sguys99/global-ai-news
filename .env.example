# 실제 값은 .env.local 에 입력한다 (git에 커밋하지 않음).
# Phase 0(Walking Skeleton)에서 직접 사용하는 키는 없으며, 이후 Phase에서 사용된다.

# --- LLM (Phase 2~) ---
# Anthropic Claude API key
ANTHROPIC_API_KEY=
# 가공에 사용할 모델 (기본: Haiku)
LLM_MODEL=claude-haiku-4-5

# --- 수집 소스 인증 (Phase 3~) ---
# Reddit OAuth2 (client_credentials). script 타입 앱 등록 후 발급.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# arXiv "유명 논문" 게이트 보강 (선택). 둘 다 없어도 동작하나 정확도/한도가 떨어진다.
# Semantic Scholar 인용수 조회 키 — 미설정 시 무키 공용 풀(429 잦음)로 폴백.
SEMANTIC_SCHOLAR_API_KEY=
# OpenAlex polite-pool 식별 이메일 (기관 조회 시 권장).
OPENALEX_MAILTO=

# --- 비용 가드 (Phase 3~) ---
# 1회 실행당 LLM 가공 상한. 신규 후보가 이보다 많으면 트렌딩 상위만 가공 (기본 150).
MAX_ITEMS_PER_RUN=150

# --- Admin 운영 콘솔 (Phase 5~) ---
# GitHub: sources.json 커밋 / workflow_dispatch 트리거용 PAT.
# Phase 3 의 GitHub Search 수집에도 사용되면 rate limit(30/분)이 완화된다(선택).
GITHUB_PAT=
# 대상 저장소 (owner/repo)
GITHUB_REPO=
# 커밋/워크플로 대상 브랜치 (기본: main)
GITHUB_BRANCH=main
# 운영자 로그인 비밀번호. 미설정 시 /admin 접근/로그인 불가.
# (Admin 세션 쿠키 HMAC 서명 키로도 사용됨)
ADMIN_PASSWORD=

# --- 정적 배포 (GitHub Pages) ---
# 프로덕션 빌드(`npm run build`, 정적 export)에서 admin/api/middleware를 산출에서
# 제외하는 빌드 전용 플래그. 로컬 `next dev`에는 적용하지 않아 admin/api가 그대로 동작.
# 실제 제외 로직은 Phase 3에서 구현(빌드 phase 감지로 대체 가능). 배포 워크플로(deploy.yml)에서만 STATIC_EXPORT=1 설정.
# output:'export'는 next.config.ts 기본값이라 토글이 필요 없다.
STATIC_EXPORT=
