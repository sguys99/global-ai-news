# 실제 값은 .env.local 에 입력한다 (git에 커밋하지 않음).
# Phase 0(Walking Skeleton)에서 직접 사용하는 키는 없으며, 이후 Phase에서 사용된다.

# --- LLM (Phase 2~) ---
# Anthropic Claude API key
ANTHROPIC_API_KEY=
# 가공에 사용할 모델 (기본: Haiku)
LLM_MODEL=claude-haiku-4-5

# --- 수집 소스 인증 (Phase 3~) ---
# Reddit OAuth2 (client_credentials). script 타입 앱 등록 후 발급.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- 비용 가드 (Phase 3~) ---
# 1회 실행당 LLM 가공 상한. 신규 후보가 이보다 많으면 트렌딩 상위만 가공 (기본 150).
MAX_ITEMS_PER_RUN=150

# --- Admin 운영 콘솔 (Phase 5~) ---
# GitHub: sources.json 커밋 / workflow_dispatch 트리거용 PAT.
# Phase 3 의 GitHub Search 수집에도 사용되면 rate limit(30/분)이 완화된다(선택).
GITHUB_PAT=
# 대상 저장소 (owner/repo)
GITHUB_REPO=
# 커밋/워크플로 대상 브랜치 (기본: main)
GITHUB_BRANCH=main
# 운영자 로그인 비밀번호. 미설정 시 /admin 접근/로그인 불가.
# (Admin 세션 쿠키 HMAC 서명 키로도 사용됨)
ADMIN_PASSWORD=
