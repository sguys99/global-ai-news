# 실제 값은 .env.local 에 입력한다 (git에 커밋하지 않음).
# Phase 0(Walking Skeleton)에서 직접 사용하는 키는 없으며, 이후 Phase에서 사용된다.

# --- LLM (Phase 2~) ---
# Anthropic Claude API key
ANTHROPIC_API_KEY=
# 가공에 사용할 모델 (기본: Haiku)
LLM_MODEL=claude-haiku-4-5

# --- 수집 소스 인증 (Phase 3~) ---
# Reddit OAuth2 (client_credentials)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Admin 운영 콘솔 (Phase 5~) ---
# GitHub: sources.json 커밋 및 workflow_dispatch 트리거용 PAT
GITHUB_PAT=
# 대상 저장소 (owner/repo)
GITHUB_REPO=
# 운영자 로그인 비밀번호
ADMIN_PASSWORD=
